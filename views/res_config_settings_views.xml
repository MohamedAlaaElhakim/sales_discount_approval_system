<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_discount_approval" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.discount.approval</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="sale.res_config_settings_view_form"/>
        <field name="arch" type="xml">

            <!-- [تم الإصلاح]: استخدام @id بدلاً من @name للبحث عن قسم التسعير (Pricing) -->
            <xpath expr="//block[@id='pricing_setting_container']" position="inside">

                <!-- البنية القياسية النظيفة والجديدة كلياً لـ Odoo 17 -->
                <setting id="discount_approval_threshold_setting"
                         string="Discount Approval Threshold"
                         help="Orders with discount exceeding this percentage will require manager approval.">

                    <field name="discount_approval_threshold" widget="percentage"/>

                </setting>

            </xpath>

        </field>
    </record>
</odoo>