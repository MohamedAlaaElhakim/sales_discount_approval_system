<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Approval History Tree View -->
    <record id="view_approval_history_tree" model="ir.ui.view">
        <field name="name">sale.order.approval.tree</field>
        <field name="model">sale.order.approval</field>
        <field name="arch" type="xml">
            <tree create="0" edit="0" delete="0"
                  decoration-info="action == 'requested'"
                  decoration-success="action == 'approved'"
                  decoration-danger="action == 'rejected'">
                <field name="date" widget="datetime"/>
                <field name="order_id"/>
                <field name="order_partner_id"/>
                <field name="user_id"/>
                <field name="action" widget="badge"
                       decoration-info="action == 'requested'"
                       decoration-success="action == 'approved'"
                       decoration-danger="action == 'rejected'"/>
                <field name="discount_percentage"/>
                <field name="order_amount_total" widget="monetary"/>
                <field name="currency_id" column_invisible="1"/>
                <field name="reason"/>
            </tree>
        </field>
    </record>

    <!-- Approval History Form View -->
    <record id="view_approval_history_form" model="ir.ui.view">
        <field name="name">sale.order.approval.form</field>
        <field name="model">sale.order.approval</field>
        <field name="arch" type="xml">
            <form create="0" edit="0" delete="0">
                <sheet>
                    <group>
                        <group>
                            <field name="order_id"/>
                            <field name="order_partner_id"/>
                            <field name="order_amount_total" widget="monetary"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                        <group>
                            <field name="user_id"/>
                            <field name="action" widget="badge"/>
                            <field name="discount_percentage"/>
                            <field name="date" widget="datetime"/>
                        </group>
                    </group>
                    <group string="Reason/Notes">
                        <field name="reason" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Approval History Search View -->
    <record id="view_approval_history_search" model="ir.ui.view">
        <field name="name">sale.order.approval.search</field>
        <field name="model">sale.order.approval</field>
        <field name="arch" type="xml">
            <search>
                <field name="order_id"/>
                <field name="user_id"/>
                <field name="order_partner_id"/>
                <separator/>
                <filter name="requested" string="Requested"
                        domain="[('action', '=', 'requested')]"/>
                <filter name="approved" string="Approved"
                        domain="[('action', '=', 'approved')]"/>
                <filter name="rejected" string="Rejected"
                        domain="[('action', '=', 'rejected')]"/>
                <separator/>
                <filter name="my_actions" string="My Actions"
                        domain="[('user_id', '=', uid)]"/>
                <separator/>
                <filter name="this_month" string="This Month"
                        domain="[('date', '&gt;=', (context_today() - relativedelta(months=1)).strftime('%Y-%m-01'))]"/>
                <group expand="0" string="Group By">
                    <filter string="Action" name="group_action"
                            context="{'group_by': 'action'}"/>
                    <filter string="User" name="group_user"
                            context="{'group_by': 'user_id'}"/>
                    <filter string="Order" name="group_order"
                            context="{'group_by': 'order_id'}"/>
                    <filter string="Date" name="group_date"
                            context="{'group_by': 'date:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Approval History Action -->
    <record id="action_approval_history" model="ir.actions.act_window">
        <field name="name">Approval History</field>
        <field name="res_model">sale.order.approval</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{'search_default_this_month': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No approval history yet
            </p>
            <p>
                Approval history will appear here when discount approvals are requested.
            </p>
        </field>
    </record>

    <!-- Menu Item -->
    <menuitem id="menu_approval_history"
              name="Approval History"
              parent="sale.sale_order_menu"
              action="action_approval_history"
              sequence="50"
              groups="sales_discount_approval_system.group_discount_manager"/>

</odoo>
