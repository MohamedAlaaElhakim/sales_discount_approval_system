<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Discount User Group -->
    <record id="group_discount_user" model="res.groups">
        <field name="name">Discount User</field>
        <field name="category_id" ref="base.module_category_sales_sales"/>
        <field name="implied_ids" eval="[(4, ref('sales_team.group_sale_salesman'))]"/>
        <field name="comment">Can request discount approval</field>
    </record>

    <!-- Discount Manager Group -->
    <record id="group_discount_manager" model="res.groups">
        <field name="name">Discount Manager</field>
        <field name="category_id" ref="base.module_category_sales_sales"/>
        <field name="implied_ids" eval="[(4, ref('group_discount_user')), (4, ref('sales_team.group_sale_manager'))]"/>
        <field name="comment">Can approve or reject discount requests</field>
    </record>

</odoo>
